<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Bayar Advogados - Advocacia Trabalhista especializada na defesa do trabalhador em Canoas e Região Metropolitana. 17 anos de experiência combatendo abusos.">
    <meta name="keywords" content="advogado trabalhista canoas, direito do trabalho, rescisão indireta, verbas rescisórias, bayar advogados">
    <title>Bayar Advogados | Advocacia Trabalhista Especializada</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;700&family=Montserrat:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

    <style>
        :root {
            --primary: #2D4B8E;
            --primary-dark: #1A2849;
            --secondary: #D4AF37; /* Toque dourado elegante para autoridade */
            --bg-light: #F8F9FA;
            --text-dark: #1E2530;
            --text-light: #FFFFFF;
            --gray-muted: #6C757D;
            --border-color: #E2E8F0;
            --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* Reset e Estilos Globais */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            outline: none;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            color: var(--text-dark);
            background-color: var(--text-light);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, .brand-font {
            font-family: 'Cinzel', serif;
            font-weight: 700;
            letter-spacing: 1px;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        img {
            max-width: 100%;
            height: auto;
            display: block;
            object-fit: cover;
        }

        section {
            padding: 100px 20px;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
        }

        /* Alinhamento de títulos */
        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-header h2 {
            font-size: 2.5rem;
            color: var(--primary-dark);
            position: relative;
            padding-bottom: 15px;
            text-transform: uppercase;
        }

        .section-header h2::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 3px;
            background-color: var(--secondary);
        }

        .section-header p {
            margin-top: 15px;
            color: var(--gray-muted);
            font-size: 1.1rem;
            font-weight: 400;
        }

        /* Botões */
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 16px 35px;
            font-weight: 600;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }

        .btn-primary {
            background-color: var(--primary);
            color: var(--text-light);
            border: 1px solid var(--primary);
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            border-color: var(--primary-dark);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background-color: transparent;
            color: var(--text-light);
            border: 2px solid var(--text-light);
        }

        .btn-secondary:hover {
            background-color: var(--text-light);
            color: var(--primary-dark);
            transform: translateY(-2px);
        }

        .btn-accent {
            background-color: var(--secondary);
            color: var(--primary-dark);
            font-weight: 700;
        }

        .btn-accent:hover {
            background-color: #c49f2f;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        /* Header Fixo */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 1000;
            background-color: rgba(26, 40, 73, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(212, 175, 55, 0.2);
            padding: 20px 0;
            transition: var(--transition);
        }

        header.scrolled {
            padding: 12px 0;
            background-color: var(--primary-dark);
        }

        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
        }

        .logo {
            display: flex;
            flex-direction: column;
        }

        .logo .main-logo {
            color: var(--text-light);
            font-size: 1.6rem;
            font-weight: 700;
        }

        .logo .sub-logo {
            color: var(--secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            font-weight: 600;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 30px;
        }

        nav ul a {
            color: var(--text-light);
            font-size: 0.85rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: var(--transition);
        }

        nav ul a:hover {
            color: var(--secondary);
        }

        .nav-cta {
            padding: 8px 18px !important;
            border: 1px solid var(--secondary);
            color: var(--secondary) !important;
        }

        .nav-cta:hover {
            background-color: var(--secondary);
            color: var(--primary-dark) !important;
        }

        .menu-toggle {
            display: none;
            color: var(--text-light);
            font-size: 1.5rem;
            cursor: pointer;
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(rgba(26, 40, 73, 0.88), rgba(26, 40, 73, 0.92)), url('foto1.webp') no-center/cover no-repeat;
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            color: var(--text-light);
            padding-top: 120px;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: 1.2sfr 0.8fr;
            gap: 40px;
            align-items: center;
        }

        .hero-content h1 {
            font-size: 3.2rem;
            line-height: 1.2;
            margin-bottom: 25px;
            color: var(--text-light);
        }

        .hero-content h1 span {
            color: var(--secondary);
        }

        .hero-content p {
            font-size: 1.2rem;
            margin-bottom: 40px;
            font-weight: 300;
            color: rgba(255,255,255,0.9);
        }

        .hero-btns {
            display: flex;
            gap: 20px;
        }

        .hero-image {
            position: relative;
            border: 1px solid rgba(212, 175, 55, 0.3);
            padding: 15px;
        }

        .hero-image img {
            width: 100%;
            height: 500px;
            object-fit: cover;
            border: 1px solid rgba(212, 175, 55, 0.2);
        }

        .hero-badge {
            position: absolute;
            bottom: -20px;
            left: -20px;
            background-color: var(--primary);
            border: 2px solid var(--secondary);
            padding: 20px;
            text-align: center;
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
        }

        .hero-badge .number {
            font-family: 'Cinzel', serif;
            font-size: 2rem;
            color: var(--secondary);
            display: block;
            font-weight: 700;
        }

        .hero-badge .text {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }

        /* Faixa de Benefícios Rápidos */
        .benefits-bar {
            background-color: var(--primary-dark);
            padding: 40px 20px;
            border-bottom: 4px solid var(--secondary);
        }

        .benefits-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .benefit-item {
            display: flex;
            align-items: center;
            gap: 20px;
            color: var(--text-light);
        }

        .benefit-item i {
            font-size: 2.5rem;
            color: var(--secondary);
        }

        .benefit-item h3 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .benefit-item p {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.7);
        }

        /* Seção O Grande Problema */
        .problem-section {
            background-color: var(--bg-light);
        }

        .problem-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        .problem-list {
            list-style: none;
            margin-top: 30px;
        }

        .problem-list li {
            position: relative;
            padding-left: 35px;
            margin-bottom: 25px;
            font-size: 1.05rem;
        }

        .problem-list li i {
            position: absolute;
            left: 0;
            top: 4px;
            color: #C53030;
            font-size: 1.2rem;
        }

        .problem-list strong {
            color: var(--primary-dark);
        }

        .problem-alert-box {
            background-color: #FFF5F5;
            border-left: 4px solid #C53030;
            padding: 30px;
            margin-top: 35px;
        }

        .problem-alert-box h4 {
            color: #9B2C2C;
            font-size: 1.2rem;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .problem-image img {
            width: 100%;
            height: 550px;
            box-shadow: 20px 20px 0px rgba(26, 40, 73, 0.05);
        }

        /* Seção Serviços (Cards) */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .service-card {
            background: var(--text-light);
            border: 1px solid var(--border-color);
            padding: 40px 30px;
            transition: var(--transition);
            position: relative;
        }

        .service-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background-color: var(--primary);
            transform: scaleX(0);
            transition: var(--transition);
            transform-origin: left;
        }

        .service-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
            border-color: transparent;
        }

        .service-card:hover::before {
            transform: scaleX(1);
        }

        .service-icon {
            width: 70px;
            height: 70px;
            background-color: var(--bg-light);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 25px;
            color: var(--primary);
            font-size: 1.8rem;
            transition: var(--transition);
        }

        .service-card:hover .service-icon {
            background-color: var(--primary);
            color: var(--text-light);
        }

        .service-card h3 {
            font-family: 'Montserrat', sans-serif;
            font-size: 1.25rem;
            color: var(--primary-dark);
            margin-bottom: 15px;
            font-weight: 700;
        }

        .service-card p {
            color: var(--gray-muted);
            font-size: 0.95rem;
            margin-bottom: 20px;
        }

        .service-link {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Seção Sobre a Autoridade */
        .about-section {
            background-color: var(--primary-dark);
            color: var(--text-light);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 0.9fr 1.1fr;
            gap: 60px;
            align-items: center;
        }

        .about-image {
            position: relative;
            border: 1px solid rgba(212, 175, 55, 0.3);
            padding: 15px;
        }

        .about-image img {
            width: 100%;
            height: 600px;
        }

        .about-content h2 {
            color: var(--text-light);
        }

        .about-subtitle {
            color: var(--secondary);
            text-transform: uppercase;
            font-weight: 600;
            font-size: 0.9rem;
            letter-spacing: 2px;
            margin-bottom: 15px;
            display: block;
        }

        .about-content p {
            margin-bottom: 25px;
            color: rgba(255,255,255,0.85);
            font-size: 1.05rem;
        }

        .about-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
            margin-top: 40px;
            border-top: 1px solid rgba(255,255,255,0.1);
            padding-top: 30px;
        }

        .stat-item h4 {
            font-family: 'Cinzel', serif;
            font-size: 2.2rem;
            color: var(--secondary);
            margin-bottom: 5px;
        }

        .stat-item p {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0;
            color: rgba(255,255,255,0.6);
        }

        /* Seção Mais Fotos (Institucional/Conexão) */
        .gallery-section {
            background-color: var(--bg-light);
        }
        
        .gallery-slider {
            display: flex;
            gap: 20px;
            overflow-x: auto;
            padding-bottom: 20px;
            scroll-snap-type: x mandatory;
        }
        
        .gallery-slider::-webkit-scrollbar {
            height: 8px;
        }
        
        .gallery-slider::-webkit-scrollbar-thumb {
            background: var(--primary);
        }

        .gallery-item {
            flex: 0 0 300px;
            scroll-snap-align: start;
            border: 1px solid var(--border-color);
            background: var(--text-light);
            padding: 10px;
        }

        .gallery-item img {
            width: 100%;
            height: 380px;
        }

        .gallery-item span {
            display: block;
            text-align: center;
            margin-top: 10px;
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--primary-dark);
            text-transform: uppercase;
        }

        /* Provas Sociais / Depoimentos */
        .testimonials-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .testimonial-card {
            background-color: var(--bg-light);
            padding: 40px 30px;
            border-bottom: 3px solid var(--primary);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .stars {
            color: var(--secondary);
            margin-bottom: 20px;
            font-size: 0.9rem;
        }

        .testimonial-card p {
            font-style: italic;
            color: var(--text-dark);
            margin-bottom: 25px;
            font-size: 0.95rem;
        }

        .client-info {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .client-info i {
            font-size: 2rem;
            color: var(--primary);
        }

        .client-info h4 {
            font-size: 1rem;
            color: var(--primary-dark);
            font-weight: 700;
        }

        /* CTA de Meio/Fim de Página */
        .cta-section {
            background: linear-gradient(rgba(26, 40, 73, 0.9), rgba(26, 40, 73, 0.95)), url('foto3.webp') center/cover no-repeat;
            color: var(--text-light);
            text-align: center;
            padding: 80px 20px;
        }

        .cta-box max-width: 800px {
            margin: 0 auto;
        }

        .cta-section h2 {
            font-size: 2.6rem;
            margin-bottom: 20px;
        }

        .cta-section p {
            font-size: 1.2rem;
            margin-bottom: 35px;
            color: rgba(255,255,255,0.9);
        }

        /* FAQ (Tag details) */
        .faq-section {
            background-color: var(--bg-light);
        }

        .faq-container {
            max-width: 800px;
            margin: 0 auto;
        }

        details {
            background-color: var(--text-light);
            border: 1px solid var(--border-color);
            margin-bottom: 15px;
            padding: 20px;
            transition: var(--transition);
        }

        details[open] {
            border-color: var(--secondary);
        }

        summary {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--primary-dark);
            cursor: pointer;
            list-style: none;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        summary::-webkit-details-marker {
            display: none;
        }

        summary::after {
            content: '\f0fe';
            font-family: 'Font Awesome 5 Free';
            font-weight: 900;
            color: var(--secondary);
            transition: var(--transition);
        }

        details[open] summary::after {
            content: '\f146';
        }

        details p {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid var(--border-color);
            color: var(--gray-muted);
            font-size: 0.95rem;
        }

        /* Localização e Contato */
        .contact-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 50px;
            align-items: start;
        }

        .contact-info h3 {
            font-size: 1.8rem;
            color: var(--primary-dark);
            margin-bottom: 25px;
        }

        .contact-details {
            margin-bottom: 35px;
        }

        .contact-line {
            display: flex;
            align-items: flex-start;
            gap: 20px;
            margin-bottom: 20px;
        }

        .contact-line i {
            font-size: 1.3rem;
            color: var(--secondary);
            margin-top: 5px;
        }

        .contact-line p {
            font-size: 1.05rem;
        }

        .map-wrapper {
            width: 100%;
            height: 400px;
            border: 1px solid var(--border-color);
            padding: 10px;
            background: var(--text-light);
        }

        .map-wrapper iframe {
            width: 100%;
            height: 100%;
        }

        /* Footer */
        footer {
            background-color: var(--primary-dark);
            color: var(--text-light);
            padding: 60px 20px 20px;
            border-top: 3px solid var(--secondary);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 1.5fr 1fr 1fr;
            gap: 40px;
            padding-bottom: 40px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .footer-logo h3 {
            font-size: 1.6rem;
            color: var(--text-light);
            margin-bottom: 10px;
        }

        .footer-logo p {
            color: rgba(255,255,255,0.6);
            font-size: 0.9rem;
        }

        .footer-links h4 {
            font-size: 1.1rem;
            color: var(--secondary);
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer-links ul {
            list-style: none;
        }

        .footer-links ul li {
            margin-bottom: 12px;
        }

        .footer-links ul a {
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
            transition: var(--transition);
        }

        .footer-links ul a:hover {
            color: var(--text-light);
            padding-left: 5px;
        }

        .copyright-bar {
            padding-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.5);
            flex-wrap: wrap;
            gap: 15px;
        }

        /* Botão Flutuante do WhatsApp Pulsante */
        .whatsapp-float {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background-color: #25D366;
            color: white;
            width: 65px;
            height: 65px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 999;
            transition: var(--transition);
            animation: pulse-whatsapp 2s infinite;
        }

        .whatsapp-float:hover {
            transform: scale(1.1);
            background-color: #20ba5a;
        }

        @keyframes pulse-whatsapp {
            0% {
                box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5);
            }
            70% {
                box-shadow: 0 0 0 20px rgba(37, 211, 102, 0);
            }
            100% {
                box-shadow: 0 0 0 0 rgba(37, 211, 102, 0);
            }
        }

        /* Responsividade Extrema */
        @media (max-width: 1024px) {
            .hero-grid, .problem-grid, .about-grid, .contact-grid {
                grid-template-columns: 1fr;
                gap: 40px;
            }
            .services-grid, .benefits-grid, .testimonials-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .hero-image img, .about-image img {
                height: 450px;
            }
        }

        @media (max-width: 768px) {
            section {
                padding: 70px 15px;
            }
            .section-header h2 {
                font-size: 2rem;
            }
            .hero-content h1 {
                font-size: 2.3rem;
            }
            .menu-toggle {
                display: block;
            }
            nav {
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                background-color: var(--primary-dark);
                display: none;
                border-bottom: 2px solid var(--secondary);
            }
            nav.active {
                display: block;
            }
            nav ul {
                flex-direction: column;
                padding: 20px;
                gap: 15px;
                text-align: center;
            }
            .services-grid, .benefits-grid, .testimonials-grid, .footer-grid {
                grid-template-columns: 1fr;
            }
            .hero-btns {
                flex-direction: column;
            }
            .hero-badge {
                bottom: 10px;
                left: 10px;
                padding: 12px;
            }
        }
    </style>
</head>
<body>

    <header id="header">
        <div class="container header-container">
            <a href="#" class="logo">
                <span class="main-logo">BAYAR</span>
                <span class="sub-logo">Advogados</span>
            </a>
            <div class="menu-toggle" id="mobile-menu"><i class="fas fa-bars"></i></div>
            <nav id="nav-menu">
                <ul>
                    <li><a href="#">Início</a></li>
                    <li><a href="#problemas">Direitos Violados</a></li>
                    <li><a href="#servicos">Áreas de Atuação</a></li>
                    <li><a href="#sobre">O Escritório</a></li>
                    <li><a href="#faq">Dúvidas Frequentes</a></li>
                    <li><a href="#contato" class="nav-cta">Falar com Advogado</a></li>
                </ul>
            </nav>
        </div>
